            "open-default-config": {
               "enabled": false
            },
            "prune-memory": {
               "enabled": false
            },
            "refresh-apps": {
               "enabled": false
            },
            "reload-scripts": {
               "enabled": false
            },
            "report-bug": {
               "enabled": false
            },
            "search-builtin-icons": {
               "enabled": false
            },
            "search-emojis": {
               "alias": "E",
