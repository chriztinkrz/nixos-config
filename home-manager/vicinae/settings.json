               "/nix/store/mhwryznfy54xadxiq5afpfazli8pd7yq-desktops/share/applications",
               "/home/chriz/.nix-profile/share/applications",
               "/nix/profile/share/applications",
               "/home/chriz/.local/state/nix/profile/share/applications",
               "/etc/profiles/per-user/chriz/share/applications",
               "/nix/var/nix/profiles/default/share/applications",
               "/run/current-system/sw/share/applications"
            ]
         }
      },
      "browser-extension": {
         "enabled": false
      },
      "calculator": {
         "entrypoints": {
            "refresh-rates": {
               "enabled": false
            }
         }
      },
      "clipboard": {
         "preferences": {
            "encryption": false,
            "eraseOnStartup": false,
            "ignorePasswords": false,
            "monitoring": true
