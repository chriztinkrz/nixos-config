{
   "$schema": "https://vicinae.com/schemas/config.json",
   "pop_to_root_on_close": true,
   "font": {
      "normal": {
         "family": "Zalando Sans Expanded",
         "size": 16
      }
   },
   "theme": {
      "dark": {
         "name": "hellwal"
      }
   },
   "launcher_window": {
      "opacity": 0.3,
      "client_side_decorations": {
         "enabled": true,
         "rounding": 11
      },
      "size": {
         "width": 847,
         "height": 528
      }
   },
   "favorites": [],
   "providers": {
      "@Gelei/store.vicinae.bluetooth": {
         "entrypoints": {
            "bluetooth-off": {
               "enabled": false
            },
            "bluetooth-on": {
               "enabled": false
            },
            "discoverable": {
               "enabled": false
            }
         }
      },
      "@dagimg-dot/store.vicinae.wifi-commander": {
         "entrypoints": {
            "manage-saved-networks": {
               "enabled": false
            },
            "restart-wifi": {
               "enabled": false
            },
            "toggle-wifi-off": {
               "enabled": false
            },
            "toggle-wifi-on": {
               "enabled": false
            }
         }
      },
      "@rastsislaux/store.vicinae.pulseaudio": {
         "entrypoints": {
            "configuration": {
               "enabled": false
            },
            "outputDevices": {
               "alias": "s"
            },
            "playback": {
               "alias": "S"
            },
            "recording": {
               "enabled": false
            }
         }
      },
      "@sovereign/store.vicinae.awww-switcher": {
         "preferences": {
            "colorGenTool": "none",
            "wallpaperPath": "/home/chriz/Pictures/Pictures/wallpapers",
            "gridRows": "3",
            "postProduction": "no",
            "showImageDetails": false,
            "toggleVicinaeSetting": false,
            "transitionDuration": "2",
            "transitionFPS": "60",
            "transitionStep": "120",
            "transitionType": "grow",
            "postCommand": "hellwal -i ${wallpaper} && ln -sf \"${wallpaper}\" \"$HOME/.cache/current_wallpaper.png\" && ~/.config/vicinae/scripts/post_wp.sh"
         },
         "entrypoints": {
            "wpgrid": {
               "alias": "w"
            },
            "wprandom": {
               "enabled": false
            }
         }
      },
      "applications": {
         "preferences": {
            "defaultAction": "launch",
            "paths": [
               "/home/chriz/.local/share/applications",
               "/nix/store/vppi7y5xzji7i8s13ma6yg66l3m9fwyq-vicinae-0.20.14/share/applications",
               "/nix/store/82ijqnr2xdzw65vsbjvgcbb7s0xrzh81-cups-2.4.16/share/applications",
               "/nix/store/7cyfjdf16s9fwny90wa7ybdmpbq5fgd4-cups-2.4.16-lib/share/applications",
