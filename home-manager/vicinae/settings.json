               "/nix/store/9rpism89x6lyjcwzzkp6kana25rs03nn-systemd-260.1/share/applications",
               "/nix/store/zcmsivndca5wmam9nwnbjrm0zkgykwfz-glib-2.86.3/share/applications",
               "/nix/store/ypj27q94ay0ybq9aa14gk0cxjv9d7z4m-gettext-1.0/share/applications",
               "/nix/store/mmzq1kq1zb40l95qf81l7cnrvgxnkp0x-libqalculate-5.10.0/share/applications",
